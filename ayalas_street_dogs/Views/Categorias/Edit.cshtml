@model ayalas_street_dogs.Models.Categorium

@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container mt-5">
    <div class="card card-custom mx-auto" style="max-width: 550px;">
        <h1 class="page-title">EDITAR CATEGORÍA @Html.DisplayFor(model => model.IdCategoria)</h1>

        <form asp-action="Edit">
            <input type="hidden" asp-for="IdCategoria" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="NombreCategoria" class="form-label control-label fw-bold">Nombre de Categoría</label>
                <input asp-for="NombreCategoria" class="form-control input-custom" />
                <span asp-validation-for="NombreCategoria" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Tipo" class="form-label control-label fw-bold">Tipo</label>
                <select asp-for="Tipo" class="form-control input-custom">
                    <option value="">-- Seleccione un tipo --</option>
                    <option value="Producto">Producto</option>
                    <option value="Servicio">Servicio</option>
                </select>
                <span asp-validation-for="Tipo" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2 mb-3">
                <button type="submit" class="btn btn-brand-gradient py-2">
                    <i class="bi bi-save-fill me-2"></i> GUARDAR CAMBIOS
                </button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-action="Details" asp-route-id="@Model?.IdCategoria" class="btn btn-outline-secondary-brand me-3">
                <i class="bi bi-eye-fill me-1"></i> Ver Detalles
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary-brand">
                <i class="bi bi-arrow-left-circle-fill me-1"></i> Regresar a Categorías
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}