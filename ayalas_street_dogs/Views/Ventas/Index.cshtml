@model IEnumerable<ayalas_street_dogs.Models.Ventum>

@{
    ViewData["Title"] = "Ventas";
}

<div class="container mt-5">
    <div class="card card-custom">
        <div class="card-header-custom">
            <h1 class="page-title">GESTIÓN DE VENTAS</h1>
            <a asp-action="Create" class="btn btn-brand-gradient">
                <i class="bi bi-plus-circle me-2"></i> Nueva Venta
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-custom mb-0">
                    <thead>
                        <tr>
                            <th>
                                <i class="bi bi-hash me-2"></i>ID
                            </th>
                            <th>
                                <i class="bi bi-calendar-event me-2"></i>Fecha
                            </th>
                            <th>
                                <i class="bi bi-person-fill me-2"></i>Cliente
                            </th>
                            <th>
                                <i class="bi bi-person-badge me-2"></i>Vendedor
                            </th>
                            <th>
                                <i class="bi bi-cash-coin me-2"></i>Total
                            </th>
                            <th>
                                <i class="bi bi-basket me-2"></i>Platillos
                            </th>
                            <th>
                                <i class="bi bi-flag-fill me-2"></i>Estado
                            </th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var venta in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">
                                        #@venta.IdVenta
                                    </td>
                                    <td>
                                        @venta.FechaV?.ToString("dd/MM/yyyy")
                                        <br />
                                        <small class="text-muted">@venta.FechaV?.ToString("HH:mm")</small>
                                    </td>
                                    <td class="fw-bold">
                                        @venta.NombreCliente
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill badge-user">
                                            <i class="bi bi-person-circle me-1"></i>@venta.Usuario
                                        </span>
                                    </td>
                                    <td>
                                        <span class="price-badge">
                                            $@venta.TotalV.ToString("N2")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge badge-items">
                                            @venta.Detalleventa.Count items
                                        </span>
                                    </td>
                                    <td>
                                        @if (venta.Estado == "Completada")
                                        {
                                            <span class="badge badge-completada">
                                                <i class="bi bi-check-circle-fill me-1"></i>Completada
                                            </span>
                                        }
                                        else if (venta.Estado == "Pendiente")
                                        {
                                            <span class="badge badge-pendiente">
                                                <i class="bi bi-clock-fill me-1"></i>Pendiente
                                            </span>
                                        }
                                        else if (venta.Estado == "Cancelada")
                                        {
                                            <span class="badge badge-cancelada">
                                                <i class="bi bi-x-circle-fill me-1"></i>Cancelada
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                @venta.Estado
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group-actions">
                                            <!-- Botón Ver Detalles -->
                                            <a asp-action="Details" asp-route-id="@venta.IdVenta"
                                               class="btn-action btn-details"
                                               title="Ver detalles">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>

                                            @if (venta.Estado == "Pendiente")
                                            {
                                                <a asp-action="Edit" asp-route-id="@venta.IdVenta"
                                                   class="btn-action btn-edit"
                                                   title="Editar">
                                                    <i class="bi bi-pencil-fill"></i>
                                                </a>

                                                <!-- Botón Completar -->
                                                <button type="button"
                                                        class="btn-action btn-complete"
                                                        onclick="cambiarEstado(@venta.IdVenta, 'Completada')"
                                                        title="Marcar como Completada">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                </button>

                                                <!-- Botón Cancelar -->
                                                <button type="button"
                                                        class="btn-action btn-delete"
                                                        onclick="cambiarEstado(@venta.IdVenta, 'Cancelada')"
                                                        title="Cancelar venta">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox" style="font-size: 3rem; color: #8AA624; opacity: 0.3;"></i>
                                        <p class="mt-3 mb-3 text-muted">No hay ventas registradas</p>
                                        <a asp-action="Create" class="btn btn-brand-gradient">
                                            <i class="bi bi-plus-circle me-2"></i>Crear primera venta
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Formulario oculto para cambiar estado -->
<form id="formCambiarEstado" asp-action="CambiarEstado" method="post" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="ventaId" />
    <input type="hidden" name="nuevoEstado" id="nuevoEstado" />
</form>

@section Scripts {
    <script>
        function cambiarEstado(ventaId, estado) {
            const mensajes = {
                'Completada': '¿Marcar esta venta como completada?',
                'Cancelada': '¿Está seguro de cancelar esta venta? Esta acción no se puede deshacer.'
            };

            if (confirm(mensajes[estado])) {
                document.getElementById('ventaId').value = ventaId;
                document.getElementById('nuevoEstado').value = estado;
                document.getElementById('formCambiarEstado').submit();
            }
        }
    </script>
}
