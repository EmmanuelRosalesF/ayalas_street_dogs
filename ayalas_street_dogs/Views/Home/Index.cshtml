@using static ayalas_street_dogs.Controllers.HomeController
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (TempData["Success"] != null)
{
<div class="alert alert-success alert-dismissible fade show mb-4">
    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold mb-3">Dashboard - Ayala's Street Dogs</h2>
        <p class="text-muted">Resumen general del sistema</p>
    </div>
    <div class="nav-item ms-3">
                    <a asp-controller="Home" asp-action="GenerarReporte" class="btn btn-pdf" target="_blank" title="Generar Reporte Dashboard">
                        <i class="bi bi-file-earmark-pdf-fill me-2"></i> Reporte PDF
                    </a>
                </div>
</div>

<!-- Tarjetas de estadísticas -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Ventas del Día</p>
                        <h3 class="mb-0 fw-bold">$@Model.VentasDelDia.ToString("N2")</h3>
                        <small class="@(Model.PorcentajeCambioVentas >= 0 ? "text-success" : "text-danger")">
                            <i class="bi bi-arrow-@(Model.PorcentajeCambioVentas >= 0 ? "up" : "down")-short"></i>
                            @Math.Abs(Model.PorcentajeCambioVentas).ToString("N1")%
                        </small>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-cash-coin text-primary" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M11 15a4 4 0 1 0 0-8 4 4 0 0 0 0 8m5-4a5 5 0 1 1-10 0 5 5 0 0 1 10 0"/>
                            <path d="M9.438 11.944c.047.596.518 1.06 1.363 1.116v.44h.375v-.443c.875-.061 1.386-.529 1.386-1.207 0-.618-.39-.936-1.09-1.1l-.296-.07v-1.2c.376.043.614.248.671.532h.658c-.047-.575-.54-1.024-1.329-1.073V8.5h-.375v.45c-.747.073-1.255.522-1.255 1.158 0 .562.378.92 1.007 1.066l.248.061v1.272c-.384-.058-.639-.27-.696-.563h-.668zm1.36-1.354c-.369-.085-.569-.26-.569-.522 0-.294.216-.514.572-.578v1.1zm.432.746c.449.104.655.272.655.569 0 .339-.257.571-.709.614v-1.195z"/>
                            <path d="M1 0a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h4.083q.088-.517.258-1H3a2 2 0 0 0-2-2V3a2 2 0 0 0 2-2h10a2 2 0 0 0 2 2v3.528c.38.34.717.728 1 1.154V1a1 1 0 0 0-1-1z"/>
                            <path d="M9.998 5.083 10 5a2 2 0 1 0-3.132 1.65 6 6 0 0 1 3.13-1.567"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Total Productos</p>
                        <h3 class="mb-0 fw-bold">@Model.TotalProductos</h3>
                        <small class="text-info">
                            <i class="bi bi-dash"></i> En menú
                        </small>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-box-seam text-success" viewBox="0 0 16 16">
                            <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Pedidos Hoy</p>
                        <h3 class="mb-0 fw-bold">@Model.PedidosHoy</h3>
                        <small class="text-success">
                            <i class="bi bi-check-circle"></i> Completados
                        </small>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-cart-check text-warning" viewBox="0 0 16 16">
                            <path d="M11.354 6.354a.5.5 0 0 0-.708-.708L8 8.293 6.854 7.146a.5.5 0 1 0-.708.708l1.5 1.5a.5.5 0 0 0 .708 0z"/>
                            <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Productos sin ventas</p>
                        <h3 class="mb-0 fw-bold">@Model.StockBajo</h3>
                        <small class="@(Model.StockBajo > 0 ? "text-warning" : "text-success")">
                            <i class="bi bi-@(Model.StockBajo > 0 ? "exclamation-triangle" : "check-circle")"></i> 
                            @(Model.StockBajo > 0 ? "Revisar" : "Todo bien")
                        </small>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-exclamation-triangle text-danger" viewBox="0 0 16 16">
                            <path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.15.15 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.2.2 0 0 1-.054.06.1.1 0 0 1-.066.017H1.146a.1.1 0 0 1-.066-.017.2.2 0 0 1-.054-.06.18.18 0 0 1 .002-.183L7.884 2.073a.15.15 0 0 1 .054-.057m1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z"/>
                            <path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gráficas y Tablas -->
<div class="row g-3">
    <!-- Gráfica de Ventas -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3">
                <h5 class="mb-0 fw-bold">Ventas de la Semana</h5>
            </div>
            <div class="card-body">
                <canvas id="salesChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Top Productos -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3">
                <h5 class="mb-0 fw-bold">Productos Más Vendidos</h5>
            </div>
            <div class="card-body">
                @if (Model.TopProductos.Any())
                {
                    <div class="list-group list-group-flush">
                        @for (int i = 0; i < Model.TopProductos.Count; i++)
                        {
                            var producto = Model.TopProductos[i];
                            var badgeClass = i == 0 ? "bg-primary" : i == 1 ? "bg-secondary" : i == 2 ? "bg-secondary" : "bg-light text-dark";
                            
                            <div class="list-group-item border-0 px-0 py-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <p class="mb-0 fw-semibold">@producto.NombrePlatillo</p>
                                        <small class="text-muted">@producto.CantidadVendida vendidos</small>
                                    </div>
                                    <span class="badge @badgeClass rounded-pill">@(i + 1)°</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4">No hay datos de ventas aún</p>
                }
            </div>
        </div>
    </div>

    <!-- Actividad Reciente -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Ventas Recientes</h5>
                    <a asp-controller="Ventas" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todas</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.VentasRecientes.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="border-0">ID</th>
                                    <th class="border-0">Cliente</th>
                                    <th class="border-0">Producto</th>
                                    <th class="border-0">Cantidad de Productos</th>
                                    <th class="border-0">Total</th>
                                    <th class="border-0">Fecha</th>
                                    <th class="border-0">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var venta in Model.VentasRecientes)
                                {
                                    var minutosTranscurridos = venta.FechaV.HasValue 
                                        ? (int)(DateTime.Now - venta.FechaV.Value).TotalMinutes 
                                        : 0;
                                    var tiempoTexto = minutosTranscurridos < 60 
                                        ? $"Hace {minutosTranscurridos} min" 
                                        : $"Hace {minutosTranscurridos / 60}h";
                                    
                                    <tr>
                                        <td>#@venta.IdVenta</td>
                                        <td>@venta.NombreCliente</td>
                                        <td>@venta.PrimerProducto</td>
                                        <td>@venta.CantidadProductos</td>
                                        <td class="fw-semibold">$@venta.TotalV.ToString("N2")</td>
                                        <td>@tiempoTexto</td>
                                        <td><span class="badge bg-success">Completado</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <p>No hay ventas recientes</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Datos desde el servidor
        var ventasSemana = @Html.Raw(Json.Serialize(Model.VentasSemana.Select(v => new { 
            fecha = v.Fecha.ToString("ddd"), 
            total = v.Total 
        })));

        // Gráfica de ventas
        const ctx = document.getElementById('salesChart').getContext('2d');
        const salesChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: ventasSemana.map(v => v.fecha),
                datasets: [{
                    label: 'Ventas ($)',
                    data: ventasSemana.map(v => v.total),
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    tension: 0.4,
                    fill: true,
                    pointRadius: 4,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false,
                        callbacks: {
                            label: function(context) {
                                return 'Ventas: $' + context.parsed.y.toLocaleString('es-MX', {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                });
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return '$' + value.toLocaleString('es-MX');
                            }
                        }
                    }
                }
            }
        });
    </script>

    <style>
        :root {
            --verde-lima: #8AA624;
            --beige: #F2E2C4;
            --naranja: #F28F16;
            --rojo-naranja: #D9580D;
            --negro: #0D0D0D;
        }

        .page-title-main {
            color: var(--negro);
            font-weight: 700;
            font-size: 2rem;
        }

        .btn-brand-gradient {
            background: linear-gradient(135deg, var(--verde-lima) 0%, var(--naranja) 100%);
            border: none;
            color: var(--beige);
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-brand-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(242, 143, 22, 0.4);
                color: var(--beige);
            }

        .summary-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            box-shadow: 0 2px 8px rgba(13, 13, 13, 0.1);
            border: 2px solid var(--beige);
            transition: all 0.3s ease;
        }

            .summary-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 4px 16px rgba(13, 13, 13, 0.15);
            }

        .summary-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--beige);
        }

            .summary-icon.bg-verde {
                background: var(--verde-lima);
            }

            .summary-icon.bg-naranja {
                background: var(--naranja);
            }

            .summary-icon.bg-rojo {
                background: var(--rojo-naranja);
            }

        .summary-content {
            flex: 1;
        }

        .summary-label {
            font-size: 0.9rem;
            color: #666;
            font-weight: 500;
        }

        .summary-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--negro);
        }

        .alert-warning-stock {
            background-color: rgba(242, 143, 22, 0.1);
            border-left: 5px solid var(--naranja);
            border-radius: 8px;
        }

        .low-stock-item {
            background: white;
            padding: 0.75rem;
            border-radius: 6px;
            border: 1px solid rgba(242, 143, 22, 0.3);
        }

        .card-custom {
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(13, 13, 13, 0.1);
            border: none;
        }

        .card-header-table {
            background: linear-gradient(135deg, var(--verde-lima) 0%, var(--naranja) 100%);
            color: var(--beige);
            padding: 1rem 1.5rem;
            border-radius: 12px 12px 0 0;
            font-weight: 600;
        }

        .bg-beige {
            background-color: var(--beige) !important;
            border-color: var(--verde-lima) !important;
            color: var(--negro);
        }

        .form-check-input:checked {
            background-color: var(--verde-lima);
            border-color: var(--verde-lima);
        }

        .badge-info-custom {
            background: var(--beige);
            color: var(--negro);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-weight: 600;
            border: 2px solid var(--verde-lima);
        }

        .table-custom {
            font-size: 0.95rem;
        }

            .table-custom thead {
                background: var(--beige);
                color: var(--negro);
                font-weight: 600;
            }

            .table-custom tbody tr {
                transition: all 0.2s ease;
            }

                .table-custom tbody tr:hover:not(.row-inactive) {
                    background-color: rgba(138, 166, 36, 0.05);
                }

        .row-inactive {
            opacity: 0.6;
            background-color: rgba(0, 0, 0, 0.02);
        }

        .badge-unit {
            background: var(--naranja);
            color: var(--beige);
            padding: 0.35rem 0.75rem;
            font-weight: 600;
        }

        .badge-activo {
            background: var(--verde-lima);
            color: var(--beige);
            padding: 0.35rem 0.75rem;
            font-weight: 600;
        }

        .badge-inactivo {
            background: #6c757d;
            color: white;
            padding: 0.35rem 0.75rem;
            font-weight: 600;
        }

        .btn-action-ajustar {
            background: var(--verde-lima);
            color: var(--beige);
            border: none;
        }

            .btn-action-ajustar:hover {
                background: #9DBE2A;
                color: var(--beige);
            }

        .btn-action-edit {
            background: var(--naranja);
            color: var(--beige);
            border: none;
        }

            .btn-action-edit:hover {
                background: #FF9A2E;
                color: var(--beige);
            }

        .btn-action-historial {
            background: #6c757d;
            color: white;
            border: none;
        }

            .btn-action-historial:hover {
                background: #5a6268;
                color: white;
            }

        .btn-action-desactivar {
            background: var(--rojo-naranja);
            color: var(--beige);
            border: none;
        }

            .btn-action-desactivar:hover {
                background: #E56A1A;
                color: var(--beige);
            }

        .btn-action-reactivar {
            background: var(--verde-lima);
            color: var(--beige);
            border: none;
        }

            .btn-action-reactivar:hover {
                background: #9DBE2A;
                color: var(--beige);
            }

        /* Estilos para el botón de Reporte PDF */
        .btn-pdf {
            background: transparent;
            border: 2px solid var(--rojo-naranja);
            color: var(--rojo-naranja);
            padding: 0.45rem 1rem;
            font-weight: 700;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.22s ease;
        }

            .btn-pdf i {
                color: inherit;
                font-size: 1.05rem;
            }

            .btn-pdf:hover {
                background: linear-gradient(90deg, var(--rojo-naranja), var(--naranja));
                color: var(--beige);
                border-color: transparent;
                box-shadow: 0 8px 22px rgba(217, 88, 13, 0.18);
                transform: translateY(-3px);
            }

            .btn-pdf:focus {
                outline: 3px solid rgba(138, 166, 36, 0.12);
                outline-offset: 2px;
            }

            .btn-pdf:active {
                transform: translateY(0);
                box-shadow: none;
            }
    </style>
}