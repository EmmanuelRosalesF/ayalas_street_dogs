@model ayalas_street_dogs.Models.Proveedor

@{
    ViewData["Title"] = "Editar";
}

<div class="container mt-5">
    <div class="card card-custom mx-auto" style="max-width: 550px;">
        <h1 class="page-title">EDITAR PROVEEDOR @Html.DisplayFor(model => model.IdProveedor)</h1>

        <form asp-action="Edit">
            <input type="hidden" asp-for="IdProveedor" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="NombreProveedor" class="form-label control-label fw-bold">Nombre de Proveedor</label>
                <input asp-for="NombreProveedor" class="form-control input-custom" />
                <span asp-validation-for="NombreProveedor" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TelefonoProveedor" class="form-label control-label fw-bold">Télefono Celular</label>
                <input asp-for="TelefonoProveedor" class="form-control input-custom" />
                <span asp-validation-for="TelefonoProveedor" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EmailProveedor" class="form-label control-label fw-bold">Correo</label>
                <input asp-for="EmailProveedor" class="form-control input-custom" />
                <span asp-validation-for="EmailProveedor" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Direccion" class="form-label control-label fw-bold">Dirección</label>
                <input asp-for="Direccion" class="form-control input-custom" />
                <span asp-validation-for="Direccion" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="IdCategoria" class="form-label control-label fw-bold">Categoría</label>
                <select asp-for="IdCategoria" class="form-control input-custom" asp-items="ViewBag.Categorias">
                </select>
                <span asp-validation-for="IdCategoria" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2 mb-3">
                <button type="submit" class="btn btn-brand-gradient py-2">
                    <i class="bi bi-save-fill me-2"></i> GUARDAR CAMBIOS
                </button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-action="Details" asp-route-id="@Model?.IdCategoria" class="btn btn-outline-secondary-brand me-3">
                <i class="bi bi-eye-fill me-1"></i> Ver Detalles
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary-brand">
                <i class="bi bi-arrow-left-circle-fill me-1"></i> Regresar a Proveedores
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
