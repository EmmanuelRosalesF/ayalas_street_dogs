@model ayalas_street_dogs.Models.Ingrediente
@{
    ViewData["Title"] = "Nuevo Ingrediente";
}

    <style>

    .btn-outline-brand {
        color: #F28F16 !important;
        background-color: #ffffff !important;
        border: 1px solid #F28F16 !important;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        transition: background-color 0.18s ease, color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    }

        .btn-outline-brand:hover,
        .btn-outline-brand:focus {
            background-color: #F28F16 !important;
            color: #ffffff !important;
            border-color: #F28F16 !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(242, 143, 22, 0.25);
            text-decoration: none;
        }

    /* Asegurar que los botones de marca se muestren correctamente */
    a.btn-brand-gradient, button.btn-brand-gradient {
        background: linear-gradient(90deg, #8AA624 0%, #F28F16 100%) !important;
        border: none !important;
        color: #ffffff !important;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    /* Focus en inputs: borde y sombra con color de marca */
    .form-control:focus {
        border-color: #F28F16 !important;
        box-shadow: 0 0 0 .25rem rgba(242, 143, 22, 0.12) !important;
        outline: none !important;
    }

    /* Mayor especificidad por si Bootstrap sigue sobrescribiendo */
    .card-body .form-control:focus {
        border-color: #F28F16 !important;
    }

    select.form-control:focus,
    textarea.form-control:focus {
        border-color: #F28F16 !important;
        box-shadow: 0 0 0 .25rem rgba(242, 143, 22, 0.12) !important;
    }
    </style>


<div class="container mt-5">
    <div class="card card-custom">
        <div class="card-header-custom d-flex justify-content-between align-items-center">
            <h1 class="page-title">NUEVO INGREDIENTE</h1>
            <div>
                <a asp-action="Index" class="btn btn-outline-brand me-2" title="Volver">
                    <i class="bi bi-arrow-left-circle me-1"></i> Volver
                </a>
            </div>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-12">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                </div>

                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="StockActual" class="form-label">Stock Actual</label>
                    <input asp-for="StockActual" class="form-control" pattern="^\d+$" title="Solo se permiten números enteros."
                           required />
                    <span asp-validation-for="StockActual" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="StockMinimo" class="form-label">Stock Mínimo</label>
                    <input asp-for="StockMinimo" class="form-control" pattern="^\d+$" title="Solo se permiten números enteros."
                           required />
                    <span asp-validation-for="StockMinimo" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="UnidadMedida" class="form-label">Unidad de Medida</label>
                    <select asp-for="UnidadMedida" class="form-control form-select">
                        <option value="">Seleccione...</option>
                        <option value="Pieza">Pieza</option>
                        <option value="Unidad">Unidad</option>
                        <option value="Paquete">Paquete</option>
                        <option value="Caja">Caja</option>
                        <option value="Kilogramo">Kilogramo</option>
                        <option value="Gramo">Gramo</option>
                        <option value="Litro">Litro</option>
                        <option value="Mililitro">Mililitro</option>
                        <option value="Metro">Metro</option>
                    </select>
                    <span asp-validation-for="UnidadMedida" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CostoUnitarioPromedio" class="form-label">Costo Unitario</label>
                    <input asp-for="CostoUnitarioPromedio" class="form-control" pattern="^\d+(\.\d{0,4})?$" 
                    oninput="this.value = this.value.replace(/[^0-9.]/g, ''); this.value = this.value.replace(/(\..*)\./g, '$1');" />
                    <span asp-validation-for="CostoUnitarioPromedio" class="text-danger"></span>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-3">
                    <a asp-action="Index" class="btn btn-outline-brand">Cancelar</a>
                    <button type="submit" class="btn btn-brand-gradient">
                        <i class="bi bi-plus-circle me-1"></i> Crear Ingrediente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function(){
            function normalizeDecimalValue(v) {
                v = (v ?? '').trim();
                if (!v) return v;
                // 1) convertimos comas a puntos
                v = v.replace(/,/g, '.');
                // 2) si hay más de un punto, todos los puntos menos el último son separadores de miles -> los quitamos
                var parts = v.split('.');
                if (parts.length > 1) {
                    var dec = parts.pop();
                    var intPart = parts.join('');
                    return intPart + '.' + dec;
                }
                return v;
            }

            var form = document.querySelector('form[asp-action="Create"], form[asp-action="Edit"]') || document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function () {
                    document.querySelectorAll('.decimal-normalize').forEach(function (input) {
                        input.value = normalizeDecimalValue(input.value);
                    });
                });
            }
        })();
    </script>
}