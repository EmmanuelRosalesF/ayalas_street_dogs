@model ayalas_street_dogs.Models.Ingrediente
@{
    ViewData["Title"] = "Editar Ingrediente";
}

<style>
    :root {
        --verde-lima: #8AA624;
        --beige: #F2E2C4;
        --naranja: #F28F16;
        --rojo-naranja: #D9580D;
        --negro: #0D0D0D;
    }

    .btn-outline-brand {
        color: var(--naranja) !important;
        background-color: #ffffff !important;
        border: 2px solid var(--naranja) !important;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-outline-brand:hover,
        .btn-outline-brand:focus {
            background-color: var(--naranja) !important;
            color: #ffffff !important;
            border-color: var(--naranja) !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(242, 143, 22, 0.25);
        }

    a.btn-brand-gradient, button.btn-brand-gradient {
        background: linear-gradient(135deg, var(--verde-lima) 0%, var(--naranja) 100%) !important;
        border: none !important;
        color: var(--beige) !important;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        a.btn-brand-gradient:hover, button.btn-brand-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(242, 143, 22, 0.4);
            color: var(--beige) !important;
        }

    .form-control:focus,
    .form-select:focus {
        border-color: var(--naranja) !important;
        box-shadow: 0 0 0 .25rem rgba(242, 143, 22, 0.12) !important;
        outline: none !important;
    }

    .card-custom {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(13, 13, 13, 0.1);
        background-color: #ffffff;
        overflow: hidden;
    }

    .card-header-custom {
        background: linear-gradient(135deg, var(--verde-lima) 0%, var(--naranja) 100%);
        padding: 20px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-title {
        color: var(--beige);
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        text-shadow: 1px 1px 2px rgba(13, 13, 13, 0.3);
    }

    .form-label {
        font-weight: 600;
        color: var(--negro);
        margin-bottom: 0.5rem;
    }

    .text-danger {
        color: var(--rojo-naranja) !important;
        font-size: 0.875rem;
    }

    .alert-warning {
        background-color: rgba(242, 143, 22, 0.1);
        border-left: 4px solid var(--naranja);
        color: var(--negro);
    }
</style>

<div class="container mt-5">
    <div class="card card-custom">
        <div class="card-header-custom d-flex justify-content-between align-items-center">
            <h1 class="page-title">
                <i class="bi bi-pencil-square me-2"></i>
                EDITAR INGREDIENTE
            </h1>
            <a asp-action="Index" class="btn btn-outline-brand" style="border-color: var(--beige) !important; color: var(--beige) !important;">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>

        <div class="card-body p-4">
            @if (!Model.Activo)
            {
                <div class="alert alert-warning mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Atención:</strong> Este ingrediente está <strong>DESACTIVADO</strong>.
                    Los cambios se guardarán pero el ingrediente seguirá inactivo.
                    <a asp-action="Reactivar" asp-route-id="@Model.IdIngrediente"
                       class="alert-link ms-2"
                       onclick="return confirm('¿Desea reactivar este ingrediente?');">
                        Reactivar ahora
                    </a>
                </div>
            }

            <form asp-action="Edit" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <input asp-for="IdIngrediente" type="hidden" />
                <input asp-for="Activo" type="hidden" />
                <input asp-for="FechaDesactivacion" type="hidden" />
                <input asp-for="MotivoDesactivacion" type="hidden" />

                <div class="col-12">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                </div>

                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label">
                        <i class="bi bi-tag me-1"></i>Nombre del Ingrediente
                    </label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Harina de trigo" required />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="StockActual" class="form-label">
                        <i class="bi bi-box me-1"></i>Stock Actual
                    </label>
                    <input asp-for="StockActual"
                           class="form-control decimal-normalize"
                           type="number"
                           step="0.001"
                           min="0"
                           placeholder="0.000"
                           required />
                    <span asp-validation-for="StockActual" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="StockMinimo" class="form-label">
                        <i class="bi bi-speedometer2 me-1"></i>Stock Mínimo
                    </label>
                    <input asp-for="StockMinimo"
                           class="form-control decimal-normalize"
                           type="number"
                           step="0.001"
                           min="0"
                           placeholder="0.000"
                           required />
                    <span asp-validation-for="StockMinimo" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="UnidadMedida" class="form-label">
                        <i class="bi bi-rulers me-1"></i>Unidad de Medida
                    </label>
                    <select asp-for="UnidadMedida" class="form-select" required>
                        <option value="">-- Seleccione una unidad --</option>
                        <optgroup label="Unidades">
                            <option value="Pieza">Pieza</option>
                            <option value="Unidad">Unidad</option>
                            <option value="Paquete">Paquete</option>
                            <option value="Caja">Caja</option>
                            <option value="Bolsa">Bolsa</option>
                        </optgroup>
                        <optgroup label="Peso">
                            <option value="Kilogramo">Kilogramo (kg)</option>
                            <option value="Gramo">Gramo (g)</option>
                            <option value="Libra">Libra (lb)</option>
                        </optgroup>
                        <optgroup label="Volumen">
                            <option value="Litro">Litro (L)</option>
                            <option value="Mililitro">Mililitro (ml)</option>
                            <option value="Galón">Galón</option>
                        </optgroup>
                        <optgroup label="Longitud">
                            <option value="Metro">Metro (m)</option>
                            <option value="Centímetro">Centímetro (cm)</option>
                        </optgroup>
                    </select>
                    <span asp-validation-for="UnidadMedida" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CostoUnitarioPromedio" class="form-label">
                        <i class="bi bi-currency-dollar me-1"></i>Costo Unitario Promedio
                    </label>
                    <div class="input-group">
                        <span class="input-group-text" style="background-color: var(--beige); border-color: var(--verde-lima);">$</span>
                        <input asp-for="CostoUnitarioPromedio"
                               class="form-control decimal-normalize"
                               type="number"
                               step="0.01"
                               min="0"
                               placeholder="0.00"
                               required />
                    </div>
                    <span asp-validation-for="CostoUnitarioPromedio" class="text-danger"></span>
                    <small class="form-text text-muted">
                        <i class="bi bi-info-circle"></i> Costo por cada unidad de medida
                    </small>
                </div>

                <div class="col-12">
                    <div class="alert" style="background-color: rgba(138, 166, 36, 0.1); border-left: 4px solid var(--verde-lima);">
                        <i class="bi bi-lightbulb me-2"></i>
                        <strong>Nota:</strong> Si necesitas ajustar el stock, usa la opción "Ajustar Stock"
                        para mantener un historial de movimientos.
                    </div>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-brand">
                        <i class="bi bi-x-circle me-1"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-brand-gradient">
                        <i class="bi bi-save me-1"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function(){
            function normalizeDecimal(v) {
                if (!v) return v;
                v = v.toString().trim();
                v = v.replace(/,/g, '.');
                var parts = v.split('.');
                if (parts.length > 1) {
                    var intPart = parts[0];
                    var decPart = parts.slice(1).join('');
                    return intPart + '.' + decPart;
                }
                return v;
            }

            var form = document.querySelector('form[asp-action="Edit"]') || document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function () {
                    document.querySelectorAll('.decimal-normalize').forEach(function (input) {
                        input.value = normalizeDecimal(input.value);
                    });
                });
            }

            // Prevenir múltiples envíos
            var submitBtn = form.querySelector('button[type="submit"]');
            if (submitBtn) {
                form.addEventListener('submit', function() {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Guardando...';
                });
            }
        })();
    </script>
}

<style>
    .btn-outline-brand:hover {
        background-color: var(--naranja) !important;
        color: white !important;
    }
</style>