@model ayalas_street_dogs.Models.Platillo

@{
    ViewData["Title"] = "Eliminar";
}

<div class="container mt-5">
    <div class="card card-custom mx-auto" style="max-width: 600px;">

        <h1 class="page-title">ELIMINAR @Html.DisplayFor(model => model.NombrePlatillo) </h1>

        <p class="lead text-center fw-bold text-brand-danger mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> ¿ESTÁ SEGURO QUE DESEA ELIMINAR ESTE REGISTRO?
        </p>

        <div class="bg-light p-4 rounded mb-4 border border-danger">
            <dl class="row">
                <dt class="col-sm-4 fw-bold text-end">
                    Precio:
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Precio)
                </dd>

                <dt class="col-sm-4 fw-bold text-end">
                    Descripción:
                </dt>
                <dd class="col-sm-8">
                    <span class="badge rounded-pill" style="background-color: #D9580D; color: white; padding: 0.5em 0.8em;">
                        @Html.DisplayFor(model => model.Descripcion)
                    </span>
                </dd>
                <dt class="col-sm-4 fw-bold text-end">
                    Categoría:
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.IdCategoriaMenuNavigation.NombreCategoriaMenu)
                </dd>
            </dl>
        </div>

        <form asp-action="Delete" class="text-center">
            <input type="hidden" asp-for="IdPlatillo" />

            <button type="submit" class="btn btn-delete-final me-4">
                <i class="bi bi-trash-fill me-1"></i> Confirmar Eliminación
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary-brand">
                <i class="bi bi-x-circle-fill me-1"></i> Cancelar
            </a>
        </form>
    </div>
</div>