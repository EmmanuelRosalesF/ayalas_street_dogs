@model ayalas_street_dogs.Models.Platillo

@{
    ViewData["Title"] = "Edit";
}

<div class="container mt-5">
    <div class="card card-custom mx-auto" style="max-width: 550px;">
        <h1 class="page-title">EDITAR PLATILLO CON ID. @Html.DisplayFor(model => model.IdPlatillo)</h1>

        <form asp-action="Edit">
            <input type="hidden" asp-for="IdPlatillo" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="NombrePlatillo" class="form-label control-label fw-bold">Nombre del Platillo</label>
                <input asp-for="NombrePlatillo" class="form-control input-custom" />
                <span asp-validation-for="NombrePlatillo" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Precio" class="form-label control-label fw-bold">Precio $</label>
                <input asp-for="Precio" class="form-control input-custom" />
                <span asp-validation-for="Precio" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Descripcion" class="form-label control-label fw-bold">Descripción</label>
                <input asp-for="Descripcion" class="form-control input-custom" />
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="IdCategoriaMenu" class="form-label control-label fw-bold">Categoría</label>
                <select asp-for="IdCategoriaMenu" class="form-control input-custom" asp-items="ViewBag.CategoriaMenu">
                </select>
                <span asp-validation-for="IdCategoriaMenu" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2 mb-3">
                <button type="submit" class="btn btn-brand-gradient py-2">
                    <i class="bi bi-save-fill me-2"></i> GUARDAR CAMBIOS
                </button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-action="Details" asp-route-id="@Model?.IdCategoriaMenu" class="btn btn-outline-secondary-brand me-3">
                <i class="bi bi-eye-fill me-1"></i> Ver Detalles
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary-brand">
                <i class="bi bi-arrow-left-circle-fill me-1"></i> Regresar a Platillos
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
