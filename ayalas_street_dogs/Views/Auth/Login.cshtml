@using ayalas_street_dogs.Models.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ayala's Street Dogs</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --color-primary: #8AA624;
            --color-secondary: #F2E2C4;
            --color-accent: #F28F16;
            --color-danger: #D9580D;
            --color-dark: #0D0D0D;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
        }

        body {
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
            background-attachment: fixed;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            position: relative;
            overflow-x: hidden;
            min-height: 100vh;
        }

            body::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -50%;
                width: 100%;
                height: 100%;
                background: radial-gradient(circle, rgba(242, 226, 196, 0.1) 0%, transparent 70%);
                animation: float 20s ease-in-out infinite;
            }

            body::after {
                content: '';
                position: absolute;
                bottom: -50%;
                left: -50%;
                width: 100%;
                height: 100%;
                background: radial-gradient(circle, rgba(217, 88, 13, 0.1) 0%, transparent 70%);
                animation: float 15s ease-in-out infinite reverse;
            }

        @@keyframes float {
            0%, 100%

        {
            transform: translate(0, 0) rotate(0deg);
        }

        50% {
            transform: translate(50px, 50px) rotate(180deg);
        }

        }

        .login-card {
            max-width: 450px;
            width: 100%;
            position: relative;
            z-index: 1;
            margin: auto;
        }

        .card {
            border: none;
            border-radius: 20px;
            overflow: visible; /* ← Cambio importante */
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            box-shadow: 0 20px 60px rgba(13, 13, 13, 0.3);
            margin-top: 100px; /* ← Espacio para el logo */
            position: relative;
        }

        .card-header-custom {
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
            padding: 120px 20px 30px; /* ← Espacio arriba para el logo */
            text-align: center;
            position: relative;
            border-radius: 20px 20px 0 0;
        }

        .logo-container {
            position: absolute;
            top: -80px; /* ← Logo sale del card */
            left: 50%;
            transform: translateX(-50%);
            display: inline-block;
            background: white;
            border-radius: 50%;
            padding: 10px;
            box-shadow: 0 10px 40px rgba(13, 13, 13, 0.2);
        }

            .logo-container img {
                height: 160px; /* ← Tamaño moderado */
                width: 160px;
                object-fit: contain;
                display: block;
            }

        .card-body {
            padding: 40px 35px !important; /* ← Padding normal, sin espacio extra */
        }

        .form-label {
            color: var(--color-dark);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        .input-group-text {
            background: var(--color-primary);
            border: 2px solid var(--color-primary);
            color: white;
            border-radius: 10px 0 0 10px;
        }

        .form-control {
            border: 2px solid #e0e0e0;
            border-left: none;
            border-radius: 0 10px 10px 0;
            padding: 12px 15px;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                border-color: var(--color-primary);
                box-shadow: 0 0 0 0.2rem rgba(138, 166, 36, 0.15);
            }

        .form-check-input:checked {
            background-color: var(--color-primary);
            border-color: var(--color-primary);
        }

        .form-check-label {
            color: var(--color-dark);
            font-size: 0.9rem;
        }

        .btn-login {
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 14px;
            border-radius: 10px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(138, 166, 36, 0.3);
            font-size: 1rem;
            letter-spacing: 0.5px;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(138, 166, 36, 0.4);
                background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-primary) 100%);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .alert {
            border-radius: 10px;
            border: none;
        }

        .alert-success {
            background: linear-gradient(135deg, rgba(138, 166, 36, 0.1) 0%, rgba(138, 166, 36, 0.05) 100%);
            color: var(--color-primary);
            border-left: 4px solid var(--color-primary);
        }

        .alert-danger {
            background: linear-gradient(135deg, rgba(217, 88, 13, 0.1) 0%, rgba(217, 88, 13, 0.05) 100%);
            color: var(--color-danger);
            border-left: 4px solid var(--color-danger);
        }

        .text-danger {
            color: var(--color-danger) !important;
        }

        .divider {
            text-align: center;
            margin: 20px 0 0 0;
            position: relative;
        }

            .divider::before {
                content: '';
                position: absolute;
                top: 50%;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(to right, transparent, #e0e0e0, transparent);
            }

            .divider span {
                background: white;
                padding: 0 15px;
                color: #999;
                font-size: 0.85rem;
                position: relative;
                z-index: 1;
            }

        .login-card {
            animation: slideUp 0.6s ease-out;
        }

        @@keyframes slideUp {
            from

        {
            opacity: 0;
            transform: translateY(50px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* Responsive */
        @@media (max-width: 576px) {
            .card

        {
            margin-top: 80px;
        }

        .card-body {
            padding: 30px 25px !important;
        }

        .card-header-custom {
            padding: 100px 20px 25px;
        }

        .logo-container {
            top: -60px;
        }

            .logo-container img {
                height: 120px;
                width: 120px;
            }

        }

        @@media (max-height: 700px) {
            .card

        {
            margin-top: 80px;
        }

        .logo-container {
            top: -60px;
        }

            .logo-container img {
                height: 120px;
                width: 120px;
            }

        .card-header-custom {
            padding: 90px 20px 20px;
        }

        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="card">
            <div class="card-header-custom">
                <div class="logo-container">
                    <img src="~/img/logoCirculo.png" alt="Logo" />
                </div>
            </div>

            <div class="card-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-4">
                        <label asp-for="UsuarioOEmail" class="form-label">
                            <i class="bi bi-person-circle me-1"></i>Usuario o Correo
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-person-fill"></i>
                            </span>
                            <input asp-for="UsuarioOEmail"
                                   class="form-control"
                                   placeholder="Tu usuario o correo@ejemplo.com"
                                   autocomplete="username" />
                        </div>
                        <span asp-validation-for="UsuarioOEmail" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Contrasena" class="form-label">
                            <i class="bi bi-shield-lock me-1"></i>Contraseña
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            <input asp-for="Contrasena"
                                   class="form-control"
                                   placeholder="Tu contraseña"
                                   autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="Contrasena" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="RecordarMe" class="form-check-input" />
                            <label asp-for="RecordarMe" class="form-check-label">
                                Mantener sesión iniciada
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-login w-100">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                    </button>
                </form>

                <div class="divider mt-4">
                    <span>Sistema de Gestión V.1.0</span>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>